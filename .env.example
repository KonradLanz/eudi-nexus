# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.

# ── ETSI Portal credentials ───────────────────────────────────────────────
ETSI_USERNAME=your-etsi-username@example.com
ETSI_PASSWORD=your-etsi-password

# Optional: future credential manager integration
# CREDENTIAL_SOURCE=keepass|gpg|env
# KEEPASS_DB_PATH=/path/to/credentials.kdbx
# GPG_KEY_ID=ABCDEF1234567890

# ── LM Studio ───────────────────────────────────────────────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234

# Preferred model: exact id as returned by GET /v1/models
# If not set, auto-selects: gemma-4 > gemma > first in list
#
# ⚡ FAST (recommended for title enrichment — ≤4 words, no reasoning needed):
#   LMSTUDIO_MODEL=phi3.5
#   LMSTUDIO_MODEL=openai/gpt-oss-20b
#   LMSTUDIO_MODEL=nvidia/nemotron-3-nano-omni
#
# 🧠 QUALITY (slower, uses reasoning tokens, good for complex titles):
#   LMSTUDIO_MODEL=google/gemma-4-31b-qat   ← thinking model: needs MAX_TOKENS ≥ 300
#   LMSTUDIO_MODEL=google/gemma-4-31b
#   LMSTUDIO_MODEL=google/gemma-3-12b
LMSTUDIO_MODEL=phi3.5

# Context window size (num_ctx). 2048 is plenty for short-title generation.
LMSTUDIO_CONTEXT=2048

# Max completion tokens.
# ⚡ Fast models (phi3.5, gpt-oss-20b):  20 is enough for ≤4 words
# 🧠 Thinking models (gemma-4-31b-qat): use ≥ 300 (reasoning tokens eat ~150-200 first)
LMSTUDIO_MAX_TOKENS=20

# ── Embedding model (for MCP index — build-index.py + mcp-server.py) ─────────
# Load this model in LM Studio under the "Embedding" tab (not Chat).
# Decision rationale: docs/architecture/embedding-models.md
#
# Recommended: nomic-embed-text-v1.5  (8192 token context, 274 MB, Apache 2.0)
# Alternative:  mxbai-embed-large     (512 token context — too short for ETSI segments)
EMBEDDING_MODEL=nomic-embed-text-v1.5

# Output dimensions. nomic supports MRL: 64 / 128 / 256 / 512 / 768
# Use 768 for best quality, 256 to reduce DB size.
EMBEDDING_DIMENSIONS=768

# ── MCP server ────────────────────────────────────────────────────────────────
# Path to the SQLite index built by build-index.py
# This file is gitignored and must be built locally: npm run index
MCP_DB_PATH=corpus/eudi-nexus.db

# ── Ollama (fallback) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Preferred Ollama model name (without tag)
# OLLAMA_MODEL=llama3.2

# ── pdf-segment: local AI heading fallback ────────────────────────────────────
# Only used when font signals are absent (scanned PDFs, size=0 from pdfplumber).
# Zero overhead when unset. Compatible with LM Studio and Ollama.
#
# LM Studio:  LOCAL_AI_URL=http://localhost:1234/v1/chat/completions
# Ollama:     LOCAL_AI_URL=http://localhost:11434/v1/chat/completions
LOCAL_AI_URL=http://localhost:1234/v1/chat/completions
# LOCAL_AI_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct

# local-ai.js configuration — copy to .env and adjust

# ── LM Studio ─────────────────────────────────────────────────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234

# Preferred model: exact id as returned by GET /v1/models
# If not set, auto-selects: gemma-4 > gemma > first in list
LMSTUDIO_MODEL=google/gemma-4-31b-qat

# Context window size passed to LM Studio (num_ctx).
# 2048 is plenty for short-title generation (input ~200 tokens, output ~5).
# Increase if you add longer prompts.
LMSTUDIO_CONTEXT=2048

# ── Ollama (fallback) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Preferred Ollama model name (without tag)
# OLLAMA_MODEL=llama3.2
